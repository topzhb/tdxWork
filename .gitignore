# ===========================
# tdxWork 根目录 .gitignore
# ===========================

# --- 大文件 / 压缩包 ---
*.rar
*.zip
*.7z

# --- SSH 密钥（绝不提交） ---
gitkey
gitkey.pub
id_ed25519
id_ed25519.pub

# --- 数据库（数百 MB，不提交） ---
db/*.db
db/*.json

# --- Python 缓存 ---
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# --- IDE / 编辑器 ---
.vscode/
.idea/
*.swp
*.swo

# --- 日志 ---
*.log

# --- 系统文件 ---
Thumbs.db
.DS_Store

# --- 本机专属配置（不同机器路径不同，不提交）---
tdx_config.py
Quan-Select/qs_config.py
tdx-analysis/tool_config.py

# --- 临时调试目录 ---
**/__temp/
Quan-Select-Backup-*/

# --- 历史归档（本地保留，不提交）---
tdx-analysis/Archive/

# --- WorkBuddy 内部文件 ---
.workbuddy/
**/.workbuddy/
